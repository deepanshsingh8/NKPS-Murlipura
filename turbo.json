{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "NEXT_PUBLIC_WEBSITE_URL",
    "NEXT_PUBLIC_CMS_URL",
    "NEXT_PUBLIC_ERP_URL",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_GA_ID",
    "NEXT_PUBLIC_GSC_VERIFICATION",
    "ANTHROPIC_API_KEY",
    "GMAIL_USER",
    "GMAIL_APP_PASSWORD",
    "FROM_EMAIL",
    "REPLY_TO_EMAIL",
    "RESEND_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
