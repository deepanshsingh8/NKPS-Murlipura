# ============================================================
#  Vercel env — WEBSITE project  (Root Directory: apps/website)
#  Import via: Project → Settings → Environment Variables → Import .env
#  Replace every <...> placeholder before importing.
# ============================================================

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# --- Site + cross-app URLs (required) ---
NEXT_PUBLIC_SITE_URL=https://www.nkpsmurlipura.com
NEXT_PUBLIC_WEBSITE_URL=https://www.nkpsmurlipura.com
NEXT_PUBLIC_CMS_URL=https://cms.nkpsmurlipura.com
NEXT_PUBLIC_ERP_URL=https://erp.nkpsmurlipura.com

# --- Email / Resend ---
RESEND_API_KEY=re_<your-resend-key>
FROM_EMAIL=NK Public School, Murlipura <noreply@nkpsmurlipura.com>
REPLY_TO_EMAIL=nkpsem@gmail.com
ADMIN_NOTIFICATION_EMAIL=nkpsem@gmail.com

# --- Chatbot (optional; omit to disable /api/chat) ---
ANTHROPIC_API_KEY=sk-ant-<your-anthropic-key>

# --- Google (optional; leave blank if unused) ---
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GSC_VERIFICATION=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
